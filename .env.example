# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/

# Base URL for waitlist email sender API
# Example: http://127.0.0.1:8000
WAITLIST_EMAIL_API_BASE_URL=http://127.0.0.1:8000

# Frontend-only toggle for local CRM test mode.
# Leave false to use the real logged-in Supabase user.
VITE_USE_TEST_CRM_USER=false

# External core services API used across multiple tools.
# Example: https://gst-tools-production.up.railway.app
VITE_API_BASE_URL=https://gst-tools-production.up.railway.app

# Symmetric secret used to encrypt Password Manager secrets at rest.
# Use a long random string and keep the same value across deployments that need to decrypt existing vaults.
PASSWORD_MANAGER_ENCRYPTION_KEY=

# S3-compatible object storage for uploaded invoice PDFs and generated result files.
# Example endpoint: https://s3.amazonaws.com or your storage provider endpoint
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET_NAME=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

